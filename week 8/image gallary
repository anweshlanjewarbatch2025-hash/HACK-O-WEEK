<div id="img5" class="lightbox"><a href="#" class="close">&times;</a><img src="https://picsum.photos/id/1043/1200/800"></div>
<div id="img6" class="lightbox"><a href="#" class="close">&times;</a><img src="https://picsum.photos/id/1050/1200/800"></div>
<div id="img7" class="lightbox"><a href="#" class="close">&times;</a><img src="https://picsum.photos/id/1060/1200/800"></div>
<div id="img8" class="lightbox"><a href="#" class="close">&times;</a><img src="https://picsum.photos/id/1074/1200/800"></div>
