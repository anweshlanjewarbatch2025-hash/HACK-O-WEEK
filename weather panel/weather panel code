
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Weather Panel</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#1e3c72,#2a5298);
color:white;
}

/* container */

.container{
display:flex;
gap:35px;
}

/* card */

.card{
width:240px;
padding:25px;
border-radius:20px;
text-align:center;
color:white;
box-shadow:0 15px 30px rgba(0,0,0,0.4);
transition:0.3s;
}

.card:hover{
transform:translateY(-10px);
}

/* different colors */

.sunny{
background:linear-gradient(135deg,#ff9966,#ff5e62);
}

.cloudy{
background:linear-gradient(135deg,#56ccf2,#2f80ed);
}

.rainy{
background:linear-gradient(135deg,#5f72bd,#9b23ea);
}

/* city */

.city{
font-size:24px;
font-weight:bold;
margin-bottom:10px;
}

/* icon */

.icon{
font-size:55px;
margin:10px 0;
}

/* temp */

.temp{
font-size:42px;
font-weight:bold;
margin-bottom:10px;
}

/* weather */

.weather{
font-size:16px;
margin-bottom:15px;
}

/* info */

.info{
display:flex;
justify-content:space-between;
border-top:1px solid rgba(255,255,255,0.4);
padding-top:8px;
margin-top:6px;
font-size:14px;
}

</style>
</head>

<body>

<div class="container">

<div class="card sunny">
<div class="city">Nagpur</div>
<div class="icon">☀️</div>
<div class="temp">29°C</div>
<div class="weather">Sunny</div>
<div class="info"><span>Humidity</span><span>31%</span></div>
<div class="info"><span>Wind</span><span>4 km/h</span></div>
</div>

<div class="card cloudy">
<div class="city">Mumbai</div>
<div class="icon">☁️</div>
<div class="temp">33°C</div>
<div class="weather">Cloudy</div>
<div class="info"><span>Humidity</span><span>65%</span></div>
<div class="info"><span>Wind</span><span>7 km/h</span></div>
</div>

<div class="card rainy">
<div class="city">Pune</div>
<div class="icon">🌧️</div>
<div class="temp">30°C</div>
<div class="weather">Rain Showers</div>
<div class="info"><span>Humidity</span><span>54%</span></div>
<div class="info"><span>Wind</span><span>12 km/h</span></div>
</div>

</div>

</body>
</html>

