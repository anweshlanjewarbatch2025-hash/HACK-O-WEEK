<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>To-Do</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f0e8;
      --ink: #1a1a1a;
      --accent: #c0392b;
      --line: #c8bfaa;
      --done: #9b8f80;
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 60px 20px;
    }

    .page {
      width: 100%;
      max-width: 480px;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: 2.8rem;
      font-weight: 700;
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 8px;
    }

    h1 span { color: var(--accent); }

    .subtitle {
      font-size: 0.7rem;
      color: var(--done);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 40px;
    }

    .input-row {
      display: flex;
      gap: 0;
      margin-bottom: 32px;
      border-bottom: 2px solid var(--ink);
    }

    .input-row input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      font-family: 'DM Mono', monospace;
      font-size: 0.9rem;
      color: var(--ink);
      padding: 10px 0;
      caret-color: var(--accent);
    }

    .input-row input::placeholder { color: var(--line); }

    .input-row button {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.4rem;
      color: var(--ink);
      padding: 0 4px 0 12px;
      transition: color 0.15s, transform 0.15s;
    }

    .input-row button:hover { color: var(--accent); transform: scale(1.2); }

    .list { list-style: none; }

    .item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--line);
      animation: slideIn 0.25s ease;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-10px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    .item input[type="checkbox"] { display: none; }

    .check-box {
      width: 18px;
      height: 18px;
      border: 2px solid var(--ink);
      flex-shrink: 0;
      margin-top: 2px;
      cursor: pointer;
      position: relative;
      transition: background 0.15s, border-color 0.15s;
    }

    .item input[type="checkbox"]:checked ~ label .check-box {
      background: var(--accent);
      border-color: var(--accent);
    }

    .item input[type="checkbox"]:checked ~ label .check-box::after {
      content: '';
      position: absolute;
      left: 3px; top: 0px;
      width: 5px; height: 9px;
      border: 2px solid #fff;
      border-top: none;
      border-left: none;
      transform: rotate(45deg);
    }

    .item label {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      cursor: pointer;
      flex: 1;
    }

    .item-text {
      font-size: 0.88rem;
      line-height: 1.5;
      color: var(--ink);
      transition: color 0.2s;
      position: relative;
    }

    .item input[type="checkbox"]:checked ~ label .item-text {
      color: var(--done);
      text-decoration: line-through;
      text-decoration-color: var(--done);
    }

    .delete-btn {
      background: none;
      border: none;
      color: var(--line);
      cursor: pointer;
      font-size: 1rem;
      margin-left: auto;
      flex-shrink: 0;
      padding: 2px 0 0 8px;
      transition: color 0.15s;
      line-height: 1;
    }

    .delete-btn:hover { color: var(--accent); }

    .empty {
      text-align: center;
      color: var(--line);
      font-size: 0.75rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 40px 0;
    }
  </style>
</head>
<body>
  <div class="page">
    <h1>to<span>·</span>do</h1>
    <p class="subtitle">keep it simple</p>

    <div class="input-row">
      <input type="text" id="taskInput" placeholder="add a task..." />
      <button onclick="addTask()">+</button>
    </div>

    <ul class="list" id="list">
      <li class="empty" id="emptyMsg">nothing here yet</li>
    </ul>
  </div>

  <script>
    let count = 0;

    const input = document.getElementById('taskInput');
    const list  = document.getElementById('list');
    const empty = document.getElementById('emptyMsg');

    input.addEventListener('keydown', e => { if (e.key === 'Enter') addTask(); });

    function addTask() {
      const text = input.value.trim();
      if (!text) return;
      empty.style.display = 'none';
      const id = 'task-' + count++;

      const li = document.createElement('li');
      li.className = 'item';
      li.id = 'item-' + id;
      li.innerHTML = `
        <input type="checkbox" id="${id}" onchange="checkDone()">
        <label for="${id}">
          <span class="check-box"></span>
          <span class="item-text">${text}</span>
        </label>
        <button class="delete-btn" onclick="deleteTask('item-${id}')">×</button>
      `;
      list.appendChild(li);
      input.value = '';
      input.focus();
    }

    function deleteTask(itemId) {
      const el = document.getElementById(itemId);
      if (el) el.remove();
      checkDone();
    }

    function checkDone() {
      const items = list.querySelectorAll('.item');
      empty.style.display = items.length === 0 ? 'block' : 'none';
    }
  </script>
</body>
</html>
